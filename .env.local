# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=917009464475
NEXT_PUBLIC_DEMO_WHATSAPP_NUMBER=917009464475

# Contact form email delivery
CONTACT_TO_EMAIL=connect@bsocio.in
CONTACT_FROM_EMAIL="AR Design Studio <noreply@bsocio.in>"
