# Auth secret
AUTH_SECRET=change-this-to-a-long-random-secret
NEXTAUTH_SECRET=change-this-to-a-long-random-secret

# MongoDB
MONGODB_URI=PASTE_YOUR_MONGODB_URI_HERE

# Super Admin
SUPER_ADMIN_NAME=AR Design Studio Admin
SUPER_ADMIN_EMAIL=connect@bsocio.in
SUPER_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
